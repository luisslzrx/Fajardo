<section id="contact" class="relative w-full py-24 px-6 overflow-hidden bg-[#0d0f18]">

  <!-- Subtle background gradient blob -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-[#6E7C93]/5 rounded-full blur-3xl pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-5xl mx-auto">

    <!-- Title -->
    <h2 class="text-white text-center text-3xl font-semibold mb-4">Contacto</h2>
    <p class="text-gray-400 text-center text-sm max-w-xl mx-auto mb-16">
      ¿Tienes un proyecto en mente? Hablemos. Estoy disponible para consultas, presupuestos y colaboraciones desde Veracruz.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-10 items-start">

      <!-- Left: contact info cards -->
      <div class="flex flex-col gap-4 md:gap-5">

        <h3 class="text-white text-base md:text-lg font-semibold flex items-center gap-3 mb-2">
          <span class="w-8 h-px bg-[#6E7C93] inline-block"></span>
          Información de contacto
        </h3>

        <!-- Email -->
        <div class="glass-container rounded-xl p-4 md:p-6 flex items-center gap-4 md:gap-5 hover:brightness-125 transition-all duration-300">
          <div class="text-[#6E7C93] shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-8 md:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-[#6E7C93] text-xs font-semibold tracking-wide mb-1">Email</p>
            <a href="mailto:contacto@arturofajardo.mx" class="text-white text-sm hover:text-[#6E7C93] transition-colors duration-200">
              contacto@arturofajardo.mx
            </a>
          </div>
        </div>

        <!-- Teléfono -->
        <div class="glass-container rounded-xl p-4 md:p-6 flex items-center gap-4 md:gap-5 hover:brightness-125 transition-all duration-300">
          <div class="text-[#6E7C93] shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-8 md:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <p class="text-[#6E7C93] text-xs font-semibold tracking-wide mb-1">Teléfono</p>
            <a href="tel:+529001234567" class="text-white text-sm hover:text-[#6E7C93] transition-colors duration-200">
              +52 900 123 4567
            </a>
          </div>
        </div>

        <!-- Ubicación -->
        <div class="glass-container rounded-xl p-4 md:p-6 flex items-center gap-4 md:gap-5 hover:brightness-125 transition-all duration-300">
          <div class="text-[#6E7C93] shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-8 md:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <p class="text-[#6E7C93] text-xs font-semibold tracking-wide mb-1">Ubicación</p>
            <p class="text-white text-sm">Veracruz, México</p>
          </div>
        </div>

        <!-- Instagram -->
        <div class="glass-container rounded-xl p-4 md:p-6 flex items-center gap-4 md:gap-5 hover:brightness-125 transition-all duration-300">
          <div class="text-[#6E7C93] shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 md:w-8 md:h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.4">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>
            </svg>
          </div>
          <div>
            <p class="text-[#6E7C93] text-xs font-semibold tracking-wide mb-1">Instagram</p>
            <a href="https://instagram.com/arturofajardo" target="_blank" rel="noopener" class="text-white text-sm hover:text-[#6E7C93] transition-colors duration-200">
              @arturofajardo
            </a>
          </div>
        </div>

      </div>

      <!-- Right: contact form -->
      <div class="glass-container rounded-xl p-6 md:p-8 flex flex-col gap-5 md:gap-6">

        <h3 class="text-white text-base md:text-lg font-semibold flex items-center gap-3">
          <span class="w-8 h-px bg-[#6E7C93] inline-block"></span>
          Envíame un mensaje
        </h3>

        <!-- Name -->
        <div class="flex flex-col gap-2">
          <label class="text-[#6E7C93] text-xs font-semibold tracking-wide">Nombre</label>
          <input
            type="text"
            placeholder="Tu nombre completo"
            class="bg-white/5 border border-white/10 rounded-lg px-3 md:px-4 py-2.5 md:py-3 text-white text-sm placeholder:text-gray-500 focus:outline-none focus:border-[#6E7C93]/60 transition-colors duration-200"
          />
        </div>

        <!-- Email -->
        <div class="flex flex-col gap-2">
          <label class="text-[#6E7C93] text-xs font-semibold tracking-wide">Email</label>
          <input
            type="email"
            placeholder="tu@email.com"
            class="bg-white/5 border border-white/10 rounded-lg px-3 md:px-4 py-2.5 md:py-3 text-white text-sm placeholder:text-gray-500 focus:outline-none focus:border-[#6E7C93]/60 transition-colors duration-200"
          />
        </div>

        <!-- Service -->
        <div class="flex flex-col gap-2">
          <label class="text-[#6E7C93] text-xs font-semibold tracking-wide">Servicio de interés</label>
          <select class="bg-white/5 border border-white/10 rounded-lg px-3 md:px-4 py-2.5 md:py-3 text-gray-400 text-sm focus:outline-none focus:border-[#6E7C93]/60 transition-colors duration-200 appearance-none">
            <option value="" disabled selected>Selecciona un servicio</option>
            <option value="diseno">Diseño Arquitectónico</option>
            <option value="obra">Proyección y Desarrollo de Obra</option>
            <option value="3d">Modelado 3D</option>
            <option value="renders">Renders Arquitectónicos</option>
            <option value="remodelacion">Remodelaciones</option>
            <option value="supervision">Supervisión de Obra</option>
          </select>
        </div>

        <!-- Message -->
        <div class="flex flex-col gap-2">
          <label class="text-[#6E7C93] text-xs font-semibold tracking-wide">Mensaje</label>
          <textarea
            rows="4"
            placeholder="Cuéntame sobre tu proyecto..."
            class="bg-white/5 border border-white/10 rounded-lg px-3 md:px-4 py-2.5 md:py-3 text-white text-sm placeholder:text-gray-500 focus:outline-none focus:border-[#6E7C93]/60 transition-colors duration-200 resize-none"
          ></textarea>
        </div>

        <!-- Submit -->
        <button
          type="button"
          class="bg-[#6E7C93] hover:bg-[#d44d30] text-white text-xs font-black tracking-widest uppercase px-6 md:px-7 py-3 md:py-4 flex items-center justify-center gap-2 transition-colors duration-200 mt-2"
        >
          Enviar mensaje
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </button>

      </div>
    </div>

  </div>
</section>