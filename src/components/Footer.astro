<footer class="w-full bg-[#080a10] border-t border-white/5 px-6 py-16">
  <div class="max-w-5xl mx-auto flex flex-col gap-12">

    <!-- Top: 3 columns -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">

      <!-- Column 1: Logo + tagline (33%) -->
      <div class="flex flex-col items-center text-center gap-3">
        <a href="/" class="text-white font-black text-2xl tracking-tight">
          Arturo Fajardo
        </a>
        <p class="text-gray-500 text-xs leading-relaxed max-w-xs">
          Arquitecto proyectista y de obra.<br/>
          Veracruz, México.
        </p>
      </div>

      <!-- Column 2: Quick links (33%) -->
      <div class="flex flex-col items-center gap-3">
        <h3 class="text-white text-sm font-semibold tracking-widest uppercase">Enlaces Rápidos</h3>
        <nav>
          <ul class="flex flex-col items-center gap-y-2">
            {[
              { label: "Inicio",       href: "#home" },
              { label: "Sobre Mí",    href: "#about" },
              { label: "Servicios",   href: "#services" },
              { label: "Proyectos",   href: "#works" },
              { label: "Habilidades", href: "#skills" },
              { label: "Experiencia", href: "#experience" },
              { label: "Contacto",    href: "#contact" },
            ].map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-gray-400 text-xs font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Column 3: Social icons (33%) -->
      <div class="flex flex-col items-center gap-3">
        <h3 class="text-white text-sm font-semibold tracking-widest uppercase">Sígueme</h3>
        <div class="flex items-center gap-3">
          <!-- Facebook -->
          <a href="#" aria-label="Facebook" class="glass-container w-9 h-9 rounded-full flex items-center justify-center hover:brightness-125 transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/60" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
            </svg>
          </a>
          <!-- Twitter/X -->
          <a href="#" aria-label="Twitter" class="glass-container w-9 h-9 rounded-full flex items-center justify-center hover:brightness-125 transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/60" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a href="#" aria-label="Instagram" class="glass-container w-9 h-9 rounded-full flex items-center justify-center hover:brightness-125 transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"/>
            </svg>
          </a>
          <!-- Behance -->
          <a href="#" aria-label="Behance" class="glass-container w-9 h-9 rounded-full flex items-center justify-center hover:brightness-125 transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/60" fill="currentColor" viewBox="0 0 24 24">
              <path d="M22 7h-7V5h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 3.211 3.483 3.312 4.588 2.029H23.726zm-7.686-3h4.965c-.105-1.477-1.136-2.219-2.477-2.219-1.466 0-2.277.768-2.488 2.219zm-9.574 6.988H-1v-9.5h5.738c3.005 0 4.218 1.51 4.218 3.224 0 1.44-.862 2.16-1.726 2.473 1.136.302 2.063 1.134 2.063 2.626 0 2.088-1.497 3.177-3.827 3.177zM1.5 14h3.076c1.164 0 1.87-.556 1.87-1.556 0-.999-.706-1.444-1.87-1.444H1.5V14zm0 4.5h3.239c1.226 0 2.108-.546 2.108-1.727S5.965 15 4.739 15H1.5v3.5z"/>
            </svg>
          </a>
          <!-- Pinterest -->
          <a href="#" aria-label="Pinterest" class="glass-container w-9 h-9 rounded-full flex items-center justify-center hover:brightness-125 transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/60" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.236 2.636 7.855 6.356 9.312-.088-.791-.167-2.005.035-2.868.181-.78 1.172-4.97 1.172-4.97s-.299-.598-.299-1.482c0-1.388.806-2.428 1.808-2.428.853 0 1.267.641 1.267 1.408 0 .858-.546 2.14-.828 3.33-.236.995.499 1.806 1.476 1.806 1.772 0 3.137-1.868 3.137-4.564 0-2.387-1.715-4.057-4.163-4.057-2.836 0-4.5 2.127-4.5 4.326 0 .856.33 1.775.741 2.276a.3.3 0 01.069.286c-.076.312-.244.995-.277 1.134-.044.183-.145.222-.335.134-1.249-.581-2.03-2.407-2.03-3.874 0-3.154 2.292-6.052 6.608-6.052 3.469 0 6.165 2.473 6.165 5.776 0 3.447-2.173 6.22-5.19 6.22-1.013 0-1.966-.527-2.292-1.148l-.623 2.378c-.226.869-.835 1.958-1.244 2.621.937.29 1.931.446 2.962.446 5.523 0 10-4.477 10-10S17.523 2 12 2z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="w-full h-px bg-white/5"></div>

    <!-- Bottom: copyright + back to top -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-600 text-xs text-center sm:text-left">
        © {new Date().getFullYear()} Arturo Fajardo · Todos los derechos reservados.
      </p>
      <p class="text-gray-600 text-xs">
        Arquitecto proyectista y de obra · Veracruz, México
      </p>
      <!-- Back to top -->
      <a
        href="#home"
        class="glass-container w-9 h-9 rounded-full flex items-center justify-center hover:brightness-125 transition-all duration-200"
        aria-label="Volver arriba"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white/60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/>
        </svg>
      </a>
    </div>

  </div>
</footer>