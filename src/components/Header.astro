<header id="mainHeader" class="fixed top-0 left-0 w-full z-50 flex items-center justify-between px-6 md:px-10 py-5 transition-all duration-300">
  <!-- Logo -->
  <a href="/" class="text-white font-black text-xl tracking-tight">
    Arturo Fajardo
  </a>

  <!-- Desktop Nav -->
  <nav class="hidden md:block">
    <ul class="flex items-center gap-8">
      <li>
        <a
          href="#home"
          class="text-white text-xs font-bold tracking-widest uppercase border-b-2 border-white pb-0.5"
        >
          Inicio
        </a>
      </li>
      <li>
        <a
          href="#about"
          class="text-white/70 text-xs font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200"
        >
          Sobre Mí
        </a>
      </li>
      <li>
        <a
          href="#services"
          class="text-white/70 text-xs font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200"
        >
          Servicios
        </a>
      </li>
      <li>
        <a
          href="#works"
          class="text-white/70 text-xs font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200"
        >
          Proyectos
        </a>
      </li>
      <li>
        <a
          href="#skills"
          class="text-white/70 text-xs font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200"
        >
          Habilidades
        </a>
      </li>
      <li>
        <a
          href="#experience"
          class="text-white/70 text-xs font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200"
        >
          Experiencia
        </a>
      </li>
      <li>
        <a
          href="#contact"
          class="text-white/70 text-xs font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200"
        >
          Contacto
        </a>
      </li>
    </ul>
  </nav>

  <!-- Mobile Menu Button -->
  <button id="menuBtn" class="md:hidden text-white p-2" onclick="toggleMenu()">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>

  <!-- Mobile Menu -->
  <div id="mobileMenu" class="fixed inset-0 bg-[#0d0f18] z-40 hidden flex-col items-center justify-center gap-8">
    <button class="absolute top-6 right-6 text-white p-2" onclick="toggleMenu()">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <ul class="flex flex-col items-center gap-6">
      <li>
        <a href="#home" onclick="toggleMenu()" class="text-white text-lg font-semibold tracking-widest uppercase">
          Inicio
        </a>
      </li>
      <li>
        <a href="#about" onclick="toggleMenu()" class="text-white/70 text-lg font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200">
          Sobre Mí
        </a>
      </li>
      <li>
        <a href="#services" onclick="toggleMenu()" class="text-white/70 text-lg font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200">
          Servicios
        </a>
      </li>
      <li>
        <a href="#works" onclick="toggleMenu()" class="text-white/70 text-lg font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200">
          Proyectos
        </a>
      </li>
      <li>
        <a href="#skills" onclick="toggleMenu()" class="text-white/70 text-lg font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200">
          Habilidades
        </a>
      </li>
      <li>
        <a href="#experience" onclick="toggleMenu()" class="text-white/70 text-lg font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200">
          Experiencia
        </a>
      </li>
      <li>
        <a href="#contact" onclick="toggleMenu()" class="text-white/70 text-lg font-semibold tracking-widest uppercase hover:text-white transition-colors duration-200">
          Contacto
        </a>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  const mobileMenu = document.getElementById('mobileMenu');
  const menuBtn = document.getElementById('menuBtn');
  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;
    if (isMenuOpen) {
      mobileMenu.classList.remove('hidden');
      mobileMenu.classList.add('flex');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      document.body.style.overflow = 'auto';
    }
  }
</script>