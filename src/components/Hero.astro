<script>
  // Typing animation: cycles through architecture roles
  const roles = [
    "Arquitecto Proyectista",
    "Arquitecto de Obra",
    "Diseño de Renders",
    "Supervisión de Obra",
  ];
  const el = document.getElementById("hero-role");
  if (el) {
    let roleIndex = 0;
    let charIndex = 0;
    let deleting = false;

    function type() {
      const current = roles[roleIndex];
      if (!deleting) {
        el.textContent = current.slice(0, charIndex + 1);
        charIndex++;
        if (charIndex === current.length) {
          deleting = true;
          setTimeout(type, 1800);
          return;
        }
      } else {
        el.textContent = current.slice(0, charIndex - 1);
        charIndex--;
        if (charIndex === 0) {
          deleting = false;
          roleIndex = (roleIndex + 1) % roles.length;
        }
      }
      setTimeout(type, deleting ? 50 : 90);
    }
    type();
  }
</script>